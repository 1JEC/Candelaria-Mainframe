# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git

# ============ DATABASE ============
# For Netlify: Use Vercel Postgres or any PostgreSQL provider
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://user:password@localhost:5432/mainframe_hq"

# ============ NEXTAUTH / AUTHENTICATION ============
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"

# Your production domain (e.g., https://mainframe-hq.netlify.app)
NEXTAUTH_URL="https://your-domain.netlify.app"

# ============ INTEGRATIONS — API Keys ============
# Social Media APIs (Meta/Facebook)
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"

# Twitter/X API
X_API_KEY="your-x-api-key"

# Email Service (Resend)
RESEND_API_KEY="re_your_resend_key"

# AI Service (Anthropic)
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"

# ============ INTERNAL WORKER ============
# API key for worker-to-portal communication
WORKER_API_KEY="your-worker-api-key"

# Portal API endpoint for worker communication
PORTAL_API_URL="https://your-domain.netlify.app/api"

# ============ ENVIRONMENT ============
NODE_ENV="production"
NEXT_PUBLIC_BRAND_NAME="Candelaria Agency"
