# Copy to .env.local and fill in actual values (NEVER commit .env.local)

# ============ DATABASE ============
DATABASE_URL="postgresql://user:password@localhost:5432/mainframe_hq"

# ============ NEXTAUTH / AUTH ============
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# ============ INTEGRATIONS — API Keys (encrypted before storage in DB) ============

# Meta Graph API
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
META_FACEBOOK_PAGE_ID="your-page-id"
META_INSTAGRAM_BUSINESS_ACCOUNT_ID="your-ig-account-id"

# X (Twitter) API
X_API_KEY="your-x-api-key"
X_API_SECRET="your-x-api-secret"
X_BEARER_TOKEN="your-x-bearer-token"
X_ACCESS_TOKEN="your-x-access-token"
X_ACCESS_SECRET="your-x-access-secret"
X_API_TIER="free"  # free, basic, pro, enterprise

# Resend
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="noreply@candelaria-agency.com"

# Anthropic API
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ============ PROTON MAIL WORKER ============
# These are ONLY used by the always-on worker, NOT the portal
PROTON_BRIDGE_HOST="localhost"
PROTON_BRIDGE_IMAP_PORT="1143"
PROTON_BRIDGE_SMTP_PORT="1025"
PROTON_MAIL_ADDRESS="your-proton@pm.me"
PROTON_MAIL_PASSWORD="your-bridge-password"

# Worker communicates with portal via this secure key
WORKER_API_KEY="worker-secret-api-key-change-this"
PORTAL_API_URL="https://hq.candelaria-agency.com/api"

# ============ ENCRYPTION ============
ENCRYPTION_KEY="your-aes-256-key-base64-encoded"

# ============ OPTIONAL: Google Places API (for prospecting) ============
GOOGLE_PLACES_API_KEY=""

# ============ ENVIRONMENT ============
NODE_ENV="development"
NEXT_PUBLIC_BRAND_NAME="Candelaria Agency"

# ============ VERCEL (production only) ============
# These are auto-set by Vercel dashboard, but documented here:
# VERCEL_ENV=production
# VERCEL_URL=hq.candelaria-agency.com
